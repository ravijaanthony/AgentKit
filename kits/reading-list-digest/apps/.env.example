# Reading List Digest — local env (kit app)
# Copy this file to .env.local in this same folder (apps/), then fill in real values.
#   cp .env.example .env.local
#
# Firecrawl, Vector DB, embedding model, and LLM are configured in Lamatic Studio
# on the flow nodes — not in this file.

# Lamatic API (Studio → Project → Settings / API keys)
LAMATIC_API_URL="https://<your-lamatic-host>"
LAMATIC_PROJECT_ID="<your-project-id>"
LAMATIC_API_KEY="<your-api-key>"

# Deployed flow IDs (Studio → each flow → URL .../flow/<id>, after Deploy)
# Index flow API Request should use Response Type = async so localhost can poll.
INDEX_ARTICLES_FLOW_ID="<flow-id-from-studio>"
SYNTHESIZE_DIGEST_FLOW_ID="<flow-id-from-studio>"
